# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
apps/**/.env

# Keep example files in git
!.env.example
!apps/**/.env.example

# ── Application Data ──────────────────────────────────────────────────────────
# Data lives under $DOCKER_DATA_DIR (/opt/docker/data), not in the repo.
# These patterns guard against accidental data files being staged locally.
/data/

# ── Backups & Archives ────────────────────────────────────────────────────────
backups/
*.tar.gz
*.zip
*.bak

# ── Database & Logs ───────────────────────────────────────────────────────────
*.sqlite
*.sqlite-*
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
*.log
*.pid

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~
.sass-cache/

# ── Python runtime & caches ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/

# ── Node runtime & debug ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
out/
dist/

# ── Environment & local overrides ─────────────────────────────────────────────
.envrc
.direnv/

