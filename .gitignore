# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
apps/**/.env

# Keep example files in git
!.env.example
!apps/**/.env.example

# ── Application Data ──────────────────────────────────────────────────────────
# Data lives under $DOCKER_DATA_DIR (/opt/docker/data), not in the repo.
# These patterns guard against accidental data files being staged locally.
/data/

# ── Backups & Archives ────────────────────────────────────────────────────────
backups/
*.tar.gz
*.zip
*.bak

# ── Database & Logs ───────────────────────────────────────────────────────────
*.sqlite
*.sqlite-*
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
*.log
*.pid

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
