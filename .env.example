# ── Identity ──────────────────────────────────────────────────────────────────
TZ=Europe/Paris
PUID=1000
PGID=1000

# ── Paths ─────────────────────────────────────────────────────────────────────
DOCKER_DIR=/opt/docker
DOCKER_DATA_DIR=/opt/docker/data

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=cestfa.app

# ── Subdomains ────────────────────────────────────────────────────────────────
ADGUARD_HOSTNAME=adguard.${DOMAIN}
BESZEL_HOSTNAME=beszel.${DOMAIN}
DISPATCHARR_HOSTNAME=dispatcharr.${DOMAIN}
FILEBROWSER_HOSTNAME=files.${DOMAIN}
GHOSTFOLIO_HOSTNAME=ghostfolio.${DOMAIN}
HONEY_HOSTNAME=${DOMAIN}
MEDIAFLOW_PROXY_HOSTNAME=mediaflow.${DOMAIN}
ZUBLO_HOSTNAME=zublo.${DOMAIN}

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate secrets with: openssl rand -hex 32
## MediaFlow
MEDIAFLOW_API_PASSWORD=password
## Ghostfolio
GHOSTFOLIO_POSTGRES_PASSWORD=password
GHOSTFOLIO_REDIS_PASSWORD=password
GHOSTFOLIO_ACCESS_TOKEN_SALT=2fb2cac8b9e107b4751945a0845440ab605a00c7b133363ddbecfe80754aa883
GHOSTFOLIO_JWT_SECRET_KEY=2fb2cac8b9e107b4751945a0845440ab605a00c7b133363ddbecfe80754aa883
## Zublo
ZUBLO_PB_ENCRYPTION_KEY=2fb2cac8b9e107b4751945a0845440ab605a00c7b133363ddbecfe80754aa883
## Beszel — fill these after first launch (see README)
BESZEL_AGENT_KEY=
BESZEL_AGENT_TOKEN=

# ── Compose ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=vps
DOCKER_NETWORK=vps_network
