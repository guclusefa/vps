# ── Identity & Paths ──────────────────────────────────────────────────────────
TZ=Europe/Paris
PUID=1000
PGID=1000
DOCKER_DATA_DIR=/opt/docker/data

# ── Domain & Subdomains ───────────────────────────────────────────────────────
DOMAIN=sefatest.duckdns.org

ADGUARD_HOSTNAME=adguard.${DOMAIN}
AIOMETADATA_HOSTNAME=aiometadata.${DOMAIN}
AIOSTREAMS_HOSTNAME=aiostreams.${DOMAIN}
BESZEL_HOSTNAME=beszel.${DOMAIN}
COMET_HOSTNAME=comet.${DOMAIN}
DISPATCHARR_HOSTNAME=dispatcharr.${DOMAIN}
FILEBROWSER_HOSTNAME=files.${DOMAIN}
GHOSTFOLIO_HOSTNAME=ghostfolio.${DOMAIN}
HONEY_HOSTNAME=${DOMAIN}
MEDIAFLOW_PROXY_HOSTNAME=mediaflow.${DOMAIN}
STIRLING_PDF_HOSTNAME=pdf.${DOMAIN}
UPTIME_KUMA_HOSTNAME=uptime.${DOMAIN}
WALLOS_HOSTNAME=wallos.${DOMAIN}
WG_EASY_HOSTNAME=vpn.${DOMAIN}

# ── Service Settings & Secrets ────────────────────────────────────────────────
# WARNING: Change all default passwords ('password') and generate strong random
# keys before deploying this stack to a public VPS/production!

# AdGuard Home
# Set to 3000 during first launch wizard, then restore/default to 80
ADGUARD_PORT=80

# AIOMetadata
AIOMETADATA_ADMIN_KEY=
AIOMETADATA_ADDON_PASSWORD=password
AIOMETADATA_TRAKT_CLIENT_ID=
AIOMETADATA_TRAKT_CLIENT_SECRET=

# AIOStreams
AIOSTREAMS_AUTH=admin:password
AIOSTREAMS_AUTH_ADMINS=admin
AIOSTREAMS_SECRET_KEY=

# Beszel
# Fill these after first launch — see README
BESZEL_AGENT_KEY=
BESZEL_AGENT_TOKEN=

# Ghostfolio
GHOSTFOLIO_POSTGRES_PASSWORD=password
GHOSTFOLIO_REDIS_PASSWORD=password
GHOSTFOLIO_ACCESS_TOKEN_SALT=
GHOSTFOLIO_JWT_SECRET_KEY=

# MediaFlow Proxy
MEDIAFLOW_API_PASSWORD=password

# Comet
COMET_ADMIN_DASHBOARD_PASSWORD=password
COMET_PROXY_DEBRID_STREAM_PASSWORD=password
COMET_SCRAPE_TORRENTIO=live
# COMET_SCRAPE_AIOSTREAMS=live
# COMET_AIOSTREAMS_URL=http://aiostreams:3000
# COMET_SCRAPE_NYAA=live
# COMET_SCRAPE_ANIMETOSHO=live
# COMET_SCRAPE_TORRENTSDB=live
# COMET_SCRAPE_PEERFLIX=live

# WireGuard (WG-Easy)
# Generate bcrypt hash with: docker run -it ghcr.io/wg-easy/wg-easy wgpw <password>
# NOTE: Escape all '$' signs in the hash by doubling them (e.g. $$2a$$12$$...)
WG_EASY_PASSWORD_HASH=

# ── Docker Compose Settings ───────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=vps
DOCKER_NETWORK=vps_network
