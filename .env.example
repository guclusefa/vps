# ── Identity ──────────────────────────────────────────────────────────────────
TZ=Europe/Paris
PUID=1000
PGID=1000

# ── Paths ─────────────────────────────────────────────────────────────────────
DOCKER_DIR=/opt/docker
DOCKER_DATA_DIR=/opt/docker/data

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=cestfa.app

# ── Subdomains ────────────────────────────────────────────────────────────────
ADGUARD_HOSTNAME=adguard.${DOMAIN}
AIOMETADATA_HOSTNAME=aiometadata.${DOMAIN}
AIOSTREAMS_HOSTNAME=aiostreams.${DOMAIN}
BESZEL_HOSTNAME=beszel.${DOMAIN}
DISPATCHARR_HOSTNAME=dispatcharr.${DOMAIN}
FILEBROWSER_HOSTNAME=files.${DOMAIN}
GHOSTFOLIO_HOSTNAME=ghostfolio.${DOMAIN}
HONEY_HOSTNAME=${DOMAIN}
MEDIAFLOW_PROXY_HOSTNAME=mediaflow.${DOMAIN}
UPTIME_KUMA_HOSTNAME=uptime.${DOMAIN}
WALLOS_HOSTNAME=wallos.${DOMAIN}

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  (use a unique value for each key)
AIOMETADATA_ADMIN_KEY=
AIOMETADATA_ADDON_PASSWORD=
AIOMETADATA_TRAKT_CLIENT_ID=
AIOMETADATA_TRAKT_CLIENT_SECRET=
AIOMETADATA_TRAKT_REDIRECT_URI=https://aiometadata.${DOMAIN}/api/auth/trakt/callback

AIOSTREAMS_AUTH=admin:password
AIOSTREAMS_AUTH_ADMINS=admin
AIOSTREAMS_SECRET_KEY=

MEDIAFLOW_API_PASSWORD=password

GHOSTFOLIO_POSTGRES_PASSWORD=
GHOSTFOLIO_REDIS_PASSWORD=
GHOSTFOLIO_ACCESS_TOKEN_SALT=
GHOSTFOLIO_JWT_SECRET_KEY=

# ── Beszel ────────────────────────────────────────────────────────────────────
# Fill these after first launch — see README
BESZEL_AGENT_KEY=
BESZEL_AGENT_TOKEN=

# ── Warp ──────────────────────────────────────────────────────────────────────
# Seconds to wait for the Warp tunnel before MediaFlow starts accepting requests
WARP_SLEEP=2

# ── Compose ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=vps
DOCKER_NETWORK=vps_network
